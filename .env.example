# API Keys Configuration
# Copy this file to .env and fill in your keys

# MiniMax API (Music + Video + Images) — REQUIRED
# Get from https://platform.minimax.io/
MINIMAX_API_KEY=your_minimax_api_key_here

# Sync.so API (Lip-sync) — OPTIONAL
# Get from https://sync.so/settings/api-keys
# If not set, lip-sync step is skipped
SYNC_API_KEY=your_sync_api_key_here
