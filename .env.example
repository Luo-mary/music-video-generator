# Get from https://platform.minimaxi.com/
MINIMAX_API_KEY=your_minimax_api_key_here

# Optional: Suno/Runway as backup
# SUNO_API_KEY=your_suno_api_key_here
# RUNWAY_API_KEY=your_runway_api_key_here
